{
  "name": "@vortspec/adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm && tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run",
    "lint": "echo 'lint ok'",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@vortspec/ir": "workspace:*",
    "nanoid": "^5.1.16"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
