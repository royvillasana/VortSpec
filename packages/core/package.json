{
  "name": "@vortspec/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./main": {
      "types": "./src/main/index.ts",
      "default": "./src/main/index.ts"
    },
    "./preload": {
      "types": "./src/preload/index.ts",
      "default": "./src/preload/index.ts"
    },
    "./*": {
      "types": "./src/shared/*.ts",
      "default": "./src/shared/*.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo 'lint ok'"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.10.0",
    "electron": "^36.4.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
