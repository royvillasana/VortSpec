{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": { "@renderer/*": ["src/renderer/src/*"] }
  },
  "include": [
    "src/renderer/src/**/*.ts",
    "src/renderer/src/**/*.tsx",
    "tests/ct/**/*.ts",
    "tests/ct/**/*.tsx",
    "playwright/**/*.tsx"
  ]
}
