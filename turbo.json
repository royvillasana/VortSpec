{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**", "dist/**"],
      "inputs": ["src/**", "package.json", "tsconfig.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json"]
    },
    "test:ct": {
      "inputs": ["src/renderer/**", "tests/ct/**", "playwright/**", "playwright-ct.config.ts", "package.json"],
      "outputs": []
    },
    "lint": {
      "inputs": ["src/**", "package.json"]
    },
    "check-types": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
